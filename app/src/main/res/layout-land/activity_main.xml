<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:textSize="22sp"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingLeft="10dp"
    android:paddingRight="10dp"
    tools:context=".MainActivity">

    <TableLayout
        android:id="@+id/table"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:stretchColumns="0,1,2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/rightPanel"

        >
        <TableRow
            android:id="@+id/rowBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/main"
            >
            <androidx.appcompat.widget.Toolbar
                android:id="@+id/my_toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="?attr/colorPrimary"
                android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
                app:popupTheme="@style/ThemeOverlay.AppCompat.Light"
                />
        </TableRow>
        <TableRow
            android:id="@+id/row0"
            android:layout_width="75dp"
            android:layout_height="50dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/rowBar"
            android:layout_marginTop="10dp"
            android:gravity="center"
            >
            <Button
                android:id="@+id/manager_button"
                style="?android:attr/buttonBarButtonStyle"
                android:text="@string/manager"
                android:textColor="@android:color/white"
                android:backgroundTint="?attr/colorPrimary"
                />
        </TableRow>
        <TableLayout
            android:stretchColumns="3">
                <TableRow
                    android:id="@+id/row1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="?android:attr/buttonBarStyle"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/row0"
                    android:gravity="center"
                    >
                    <Button
                        android:id="@+id/b1"
                        style="?android:attr/buttonBarButtonStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/b1"
                        android:textColor="@android:color/white"
                        android:backgroundTint="?attr/colorPrimary"

                        />

                <Button
                    android:id="@+id/b2"
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/b2"
                    android:textColor="@android:color/white"
                    android:backgroundTint="?attr/colorPrimary"
                    />

                <Button
                    android:id="@+id/b3"
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/b3"
                    android:textColor="@android:color/white"
                    android:backgroundTint="?attr/colorPrimary"

                    />

            </TableRow>
            <TableRow
                android:id="@+id/row2"
                style="?android:attr/buttonBarStyle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/row1"
                app:layout_constraintBottom_toTopOf="@id/row1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                >
                <Button
                    android:id="@+id/b4"
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/b4"
                    android:textColor="@android:color/white"
                    android:backgroundTint="?attr/colorPrimary"

                    />
                <Button
                    android:id="@+id/b5"
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/b5"
                    android:textColor="@android:color/white"
                    android:backgroundTint="?attr/colorPrimary"

                    />
                <Button
                    android:id="@+id/b6"
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/b6"
                    android:textColor="@android:color/white"
                    android:backgroundTint="?attr/colorPrimary"
                    />

            </TableRow>
            <TableRow
                android:id="@+id/row3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="?android:attr/buttonBarStyle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/row2"
                android:gravity="center">
                <Button
                    android:id="@+id/b7"
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/b7"
                    android:textColor="@android:color/white"
                    android:backgroundTint="?attr/colorPrimary"

                    />
                <Button
                    android:id="@+id/b8"
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/b8"
                    android:textColor="@android:color/white"
                    android:backgroundTint="?attr/colorPrimary"

                    />
                <Button
                    android:id="@+id/b9"
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/b9"
                    android:textColor="@android:color/white"
                    android:backgroundTint="?attr/colorPrimary"

                    />
            </TableRow>
            <TableRow
                android:id="@+id/row4"
                style="?android:attr/buttonBarStyle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/row3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center">
                <Button
                    android:id="@+id/clear_button"
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/clear"
                    android:textColor="@android:color/white"
                    android:backgroundTint="?attr/colorPrimary"

                    />
                <Button
                    android:id="@+id/b0"
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/b0"
                    android:textColor="@android:color/white"
                    android:backgroundTint="?attr/colorPrimary"

                    />
            </TableRow>
        </TableLayout>
    </TableLayout>

    <LinearLayout
        android:id="@+id/rightPanel"
        android:orientation="vertical"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="15dp"
        android:padding="10dp"
        app:layout_constraintStart_toEndOf="@id/table"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/selected_product"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:hint="@string/product_type"
            android:gravity="center"
            />

        <TextView
            android:id="@+id/quantity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:hint="@string/quantity_text"
            android:layout_gravity="center"
            />
        <TextView
            android:id="@+id/total"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:hint="@string/total_text"
            android:gravity="center"
            />


        <ListView
            android:id="@+id/list"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            />

        <Button
            android:id="@+id/buy_button"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="50dp"
            android:text="@string/buy_button"
            android:textColor="@android:color/white"
            android:backgroundTint="?attr/colorPrimary"
            />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>